# ==========================================
# JWST Data, Caches & Outputs
# ==========================================
crds_cache/
*.fits
*.h5
*.pkl
*.npy
*.txt
*.csv
*.png
*.pdf

# Keep the directory structure intact, but ignore all contents
inputs/*
!inputs/.gitkeep
outputs/*
!outputs/.gitkeep
logs/*
!logs/.gitkeep

# ==========================================
# Configurations
# ==========================================
# Ignore the generated run-specific configuration folders
configs/eureka_runs/
configs/exotedrf_runs/
# (default_eureka and default_exotedrf are NOT ignored, so they will be pushed!)

# ==========================================
# Python & OS files
# ==========================================
__pycache__/
*.pyc
.DS_Store
.ipynb_checkpoints/

# ==========================================
# IGNORE NESTED BACKEND REPOSITORIES 
# ==========================================
sparta/
exoTEDRF/
exotedrf/
Eureka/
eureka/